{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist/electron",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/electron/**/*", "src/core/**/*"],
  "exclude": [
    "node_modules",
    "tests/**",
    "src/core/collectors/cursor.ts",
    "src/cli/**/*"
  ]
}
